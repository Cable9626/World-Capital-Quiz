<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Capital City Quiz</title>

  <link rel="stylesheet" href="/css/style.css">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap"
    rel="stylesheet">
</head>

<body>

<main>

<% if (gameOver) { %>

  <div class="quiz-card">
    <h1>Game Over!</h1>

    <h2>Your final score: <%= totalScore %></h2>

    <form action="/" method="get">
      <button class="play-again-btn" type="submit">
        Play Again
      </button>
    </form>
  </div>

<% } else { %>

  <form class="container" action="/submit" method="post">

    <!-- Hidden country sent to the backend -->
    <input
      type="hidden"
      name="country"
      value="<%= question.country %>"
    >

    <div class="quiz-header">
  <h2>🌍 World Capital Quiz</h2>

  <div class="score">
    🏆 <span><%= totalScore %></span>
  </div>
</div>

<section class="question">
      <p>What is the capital city of</p>
      <h1><%= question.country %></h1>
    </section>

    <div class="answer-section">

      <input
        type="text"
        name="answer"
        id="userInput"
        placeholder="Enter the capital"
        autocomplete="off"
        autofocus
      >

      <button class="submit-btn" type="submit">
        Submit Answer

        <% if (wasCorrect === true) { %>
          <span class="checkmark">✔</span>
        <% } %>

      </button>

    </div>

  </form>

<% } %>

</main>
</body>
</html>