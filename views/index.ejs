<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Capital City Quiz</title>
  <link rel="stylesheet" href="/styles/main.css">
</head>

<body>

<% if (gameOver) { %>

  <div class="container">
    <h1>Game Over!</h1>

    <h2>Your final score: <%= totalScore %></h2>

    <form action="/" method="get">
      <button type="submit">Play Again</button>
    </form>
  </div>

<% } else { %>

  <form class="container" action="/submit" method="post">

    <input
      type="hidden"
      name="country"
      value="<%= question.country %>"
    >

    <div class="horizontal-container">
      <h3>
        Total Score:
        <span id="score"><%= totalScore %></span>
      </h3>
    </div>

    <h1 id="countryName">
      <%= question.country %>
    </h1>

    <div class="answer-container">
      <input
        type="text"
        name="answer"
        id="userInput"
        placeholder="Enter the capital"
        autocomplete="off"
        autofocus
      >
    </div>

    <button type="submit">
      SUBMIT

      <% if (wasCorrect === true) { %>
        <span class="checkmark">✔</span>
      <% } %>

    </button>

  </form>

<% } %>

</body>
</html>